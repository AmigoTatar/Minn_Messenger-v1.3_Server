datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  avatar    String   @default("")
  status    String   @default("online")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
